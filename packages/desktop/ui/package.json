{
  "name": "noverterm-ui",
  "version": "0.1.0",
  "description": "SvelteKit frontend for noverterm desktop app",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
