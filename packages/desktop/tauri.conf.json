{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "noverterm",
  "version": "0.7.1",
  "identifier": "com.noverwork.noverterm",
  "build": {
    "beforeDevCommand": {
      "cwd": "ui",
      "script": "npm run dev"
    },
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": {
      "cwd": "ui",
      "script": "npm run build"
    },
    "frontendDist": "ui/dist"
  },
  "app": {
    "windows": [
      {
        "title": "noverterm",
        "width": 1200,
        "height": 800,
        "maximized": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
