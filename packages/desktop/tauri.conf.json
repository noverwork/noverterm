{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "noverterm",
  "version": "0.9.0",
  "identifier": "com.noverwork.noverterm",
  "build": {
    "beforeDevCommand": {
      "cwd": "ui",
      "script": "npm run dev"
    },
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": {
      "cwd": "ui",
      "script": "npm run build"
    },
    "frontendDist": "ui/dist"
  },
  "app": {
    "windows": [
      {
        "title": "noverterm",
        "width": 1200,
        "height": 800,
        "maximized": true,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDE4MEMzRjE2MjBBMjcyNDEKUldSQmNxSWdGajhNR0V1ay92YWgzcFlMRG4rMENNeDFEQWZoMEMweXg0Um5PUGYySEpSaURLWjAK",
      "endpoints": [
        "https://github.com/noverwork/noverterm/releases/latest/download/latest.json"
      ]
    }
  }
}
