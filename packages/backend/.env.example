# Backend
APP_HOST=127.0.0.1
APP_PORT=3000

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/app

# Logging (RUST_LOG)
RUST_LOG=info

# Password reset email
BACKEND_URL=https://noverterm.noverwork.com
SMTP_HOST=smtp.example.com
SMTP_PORT=587
# SMTP_TLS_MODE defaults to starttls unless SMTP_PORT is 465, where it defaults to tls.
# Use one of: starttls, tls, plain.
SMTP_TLS_MODE=starttls
SMTP_USERNAME=user
SMTP_PASSWORD=password
SMTP_FROM=Noverterm <noreply@example.com>
