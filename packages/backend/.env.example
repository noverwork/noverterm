# Backend
APP_HOST=127.0.0.1
APP_PORT=3000
JWT_SECRET=development-only-jwt-secret

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/app

# Logging (RUST_LOG)
RUST_LOG=info

# Password reset email
BACKEND_URL=https://noverterm.noverwork.com
SMTP_HOST=smtp.example.com
SMTP_PORT=587
# Required. Use one of: starttls, tls, plain.
SMTP_TLS_MODE=starttls
SMTP_USERNAME=user
SMTP_PASSWORD=password
SMTP_FROM=Noverterm <noreply@example.com>
