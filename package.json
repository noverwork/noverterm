{
  "name": "novercpa",
  "version": "0.1.0",
  "description": "",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n frontend,backend -c cyan,yellow \"npm run frontend:dev\" \"npm run backend:dev\"",
    "frontend:dev": "vite dev",
    "backend:dev": "dotenv -e packages/backend/.env -- cargo run -p backend",
    "tauri:dev": "tauri dev",
    "frontend:build": "vite build",
    "backend:build": "cargo build -p backend --release",
    "desktop:build": "tauri build",
    "frontend:preview": "vite preview",
    "frontend:check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "frontend:check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "tauri:export-types": "cargo run --bin export-types --manifest-path packages/desktop/Cargo.toml",
    "tauri:cli": "tauri",
    "migrator:up": "dotenv -e packages/backend/.env -- cargo run -p migrator -- up",
    "migrator:create": "dotenv -e packages/backend/.env -- cargo run -p migrator -- create",
    "migrator:down": "dotenv -e packages/backend/.env -- cargo run -p migrator -- down",
    "migrator:refresh": "npm run migrator:down && npm run migrator:up",
    "migrator:schema": "dotenv -e packages/backend/.env -- diesel print-schema --config-file packages/orm/diesel.toml > packages/orm/src/schema.rs || echo 'DB not found, run migrator:up first'",
    "ms:start": "./scripts/start-ms.sh",
    "ms:stop": "./scripts/stop-ms.sh",
    "ms:restart": "npm run ms:stop && npm run ms:start",
    "ms:reset": "npm run ms:stop -- --delete && npm run ms:start",
    "ms:build": "./scripts/start-ms.sh --build",
    "typecheck": "npm run frontend:check",
    "format": "prettier --write \"src/**/*\" && cargo fmt --workspace",
    "format:check": "prettier --check \"src/**/*\" && cargo fmt --workspace -- --check",
    "lint": "eslint . && cargo clippy --workspace -- -D warnings",
    "lint:fix": "eslint . --fix && cargo clippy --workspace --fix --allow-dirty",
    "ci": "npm run format:check && npm run lint && npm run typecheck && npm run backend:build && npm run frontend:build",
    "clean": "rm -rf target dist build .svelte-kit"
  },
  "license": "MIT",
  "dependencies": {
    "@lucide/svelte": "^1.8.0",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@sveltejs/adapter-static": "^3.0.6",
    "@sveltejs/kit": "^2.9.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@tailwindcss/vite": "^4.2.2",
    "@tauri-apps/cli": "^2",
    "concurrently": "^9.2.1",
    "dotenv-cli": "^8.0.0",
    "eslint": "^10.2.0",
    "eslint-plugin-svelte": "^3.17.0",
    "globals": "^17.5.0",
    "svelte": "^5.55.3",
    "svelte-check": "^4.0.0",
    "svelte-eslint-parser": "^1.6.0",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.58.1",
    "vite": "^6.0.3"
  }
}
